# ============================================================
# PairFlow — Element Pairing & Review Automation Bot
# Copy to .env and fill REAL values locally. NEVER commit .env.
# ============================================================

# ---------- App / Environment ----------
APP_ENV=development                 # development | production
APP_PORT=5000
LOG_LEVEL=info                      # debug | info | warning | error

# ---------- Admin (control panel login) ----------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_strong     # hashed on first run
SESSION_SECRET=generate_a_long_random_string

# ---------- Security ----------
# Fernet key (urlsafe base64, 32 bytes) — encrypts secrets stored in the DB.
# Generate: python -c "import base64,os;print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
SECRETS_ENCRYPTION_KEY=generate_a_32_byte_fernet_key

# ---------- Database (PostgreSQL) ----------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=element_bot
DB_USER=postgres
DB_PASSWORD=your_db_password

# ---------- Redis (Celery broker + cache) — Phase 2 ----------
REDIS_URL=redis://localhost:6379/0

# ---------- Element / Matrix (E2EE room) — Phase 1 ----------
MATRIX_HOMESERVER_URL=https://matrix.org
MATRIX_BOT_USERNAME=@yourbot:matrix.org
MATRIX_BOT_PASSWORD=bot_account_password
MATRIX_ROOM_ID=!yourPairingRoomId:matrix.org
# Task room — bot reads developer task assignments here (no posting).
MATRIX_TASK_ROOM_ID=!yourTaskRoomId:matrix.org
MATRIX_DEVICE_ID=PAIRFLOWBOT1
# Leave empty in normal operation — password login persists a fresh token to data/matrix_session.json.
# Only set temporarily for one-off bootstrap/debug; do not commit real tokens.
MATRIX_ACCESS_TOKEN=
# Optional — team lead / room poster token so PairFlow can read member messages
# (Element → Settings → Help & About → Access Token). Use a dedicated device ID.
MATRIX_ROOM_READER_TOKEN=
MATRIX_ROOM_READER_DEVICE_ID=
# Element recovery key (spaces optional) — backup passphrase for E2EE store
MATRIX_RECOVERY_KEY=
MATRIX_E2EE_STORE_PATH=./data/matrix_store
MATRIX_PICKLE_KEY=generate_a_random_pickle_key

# ---------- LLM (provider-agnostic) — Phase 4 ----------
LLM_PROVIDER=anthropic              # anthropic | openai | gemini | openrouter
LLM_API_KEY=your_llm_api_key
LLM_MODEL=your_model_name

# ---------- Scheduling ----------
TIMEZONE=Asia/Karachi
DAILY_SEND_TIME=11:00               # 24h, in TIMEZONE
WORKING_DAYS=mon,tue,wed,thu,fri
TIMELINESS_CUTOFF=23:59             # same-day cutoff for "on-time"
