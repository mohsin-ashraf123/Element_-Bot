# ============================================================
# .env.example  —  Element Pairing & Review Automation Bot
# Copy to .env and fill REAL values locally. NEVER commit .env.
# NEVER paste real secrets into chat or version control.
# ============================================================

# ---------- App / Environment ----------
APP_ENV=development                 # development | production
APP_PORT=8000
LOG_LEVEL=info                      # debug | info | warning | error

# ---------- Admin (control panel login) ----------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_strong     # you set this; will be hashed on first run
SESSION_SECRET=generate_a_long_random_string

# ---------- Security ----------
# Used to encrypt secrets/tokens stored in the DB (32-byte key, base64/hex)
SECRETS_ENCRYPTION_KEY=generate_a_32_byte_key

# ---------- Database (PostgreSQL) ----------
DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/pairingbot

# ---------- Redis (Celery broker + cache) ----------
REDIS_URL=redis://redis:6379/0

# ---------- Element / Matrix (E2EE room) ----------
MATRIX_HOMESERVER_URL=https://matrix.org        # or your self-hosted homeserver
MATRIX_BOT_USERNAME=@yourbot:matrix.org         # bot's full Matrix user ID
MATRIX_BOT_PASSWORD=bot_account_password        # for first login + E2EE device setup
MATRIX_ROOM_ID=!yourRoomId:matrix.org           # the ONE target room (bot must be joined)
MATRIX_E2EE_STORE_PATH=/data/matrix_store       # persistent volume path
MATRIX_PICKLE_KEY=generate_a_random_pickle_key  # unlocks the E2EE store

# ---------- LLM (provider-agnostic; choose later) ----------
LLM_PROVIDER=anthropic              # anthropic | openai | gemini  (set when decided)
LLM_API_KEY=your_llm_api_key
LLM_MODEL=your_model_name

# ---------- Scheduling ----------
TIMEZONE=Asia/Karachi
DAILY_SEND_TIME=11:00               # 24h, in TIMEZONE
WORKING_DAYS=mon,tue,wed,thu,fri
TIMELINESS_CUTOFF=23:59             # same-day cutoff for "on-time" (OPEN DECISION default)
